[global]
  monitor = 0
  follow = mouse
  width = 280
  height = 80
  origin = top-right
  offset = 10x40
  scale = 0
  notification_limit = 5
  progress_bar = false

  padding = 8
  horizontal_padding = 10
  text_icon_padding = 0
  frame_width = 0
  gap_size = 4
  separator_height = 0

  format = "<b>%a</b>\n%s"

  font = JetBrainsMono Nerd Font 10

  alignment = left
  vertical_alignment = center
  show_age_threshold = -1
  ellipsize = middle
  ignore_newline = yes
  stack_duplicates = true
  hide_duplicate_count = false
  show_indicators = no

  icon_theme = Papirus, hicolor
  enable_recursive_icon_lookup = true
  icon_position = left
  min_icon_size = 0
  max_icon_size = 24

  sticky_history = yes
  history_length = 20

  dmenu = /usr/bin/rofi -dmenu -p dunst
  browser = /usr/bin/brave

  always_run_script = false
  title = Dunst
  class = Dunst
  corner_radius = 6
  ignore_dbusclose = false
  force_xwayland = false
  force_xinerama = false
  mouse_left_click = close_current
  mouse_middle_click = do_action, close_current
  mouse_right_click = close_all

[experimental]
  per_monitor_dpi = false

[urgency_low]
  background = "#1d1f21"
  foreground = "#c5c8c6"
  frame_color = "#373b41"
  timeout = 4
  script = "~/.config/dunst/notify-sound.sh"

[urgency_normal]
  background = "#1d1f21"
  foreground = "#c5c8c6"
  frame_color = "#81a2be"
  timeout = 6
  script = "~/.config/dunst/notify-sound.sh"

[urgency_critical]
  background = "#1d1f21"
  foreground = "#c5c8c6"
  frame_color = "#a54242"
  timeout = 0

[brave]
  appname = Brave
  format = "<b>%a</b>\n%s"
  max_body_lines = 0
  timeout = 5
